meta {
  name: Get Token
  type: http
  seq: 1
}

post {
  url: http://localhost:8180/realms/app/protocol/openid-connect/token
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  grant_type: password
  client_id: app-client
  username: test-host
  password: local_dev_only
}

script:post-response {
  bru.setVar("token", res.body.access_token);
}
