# Copy to .env and adjust if needed. These are local-only dev defaults (see
# docker-compose.yml) - never put real/shared secrets in this file or .env.
# Off the standard 5432 on purpose, to avoid colliding with other Postgres instances
# already running on your machine (e.g. other projects' dev servers).
POSTGRES_PORT=5442
DATABASE_URL=postgres://effective_app:local_dev_only@localhost:5442/effective_app

MAILPIT_SMTP_PORT=11025
MAILPIT_WEB_PORT=18025

# Keycloak (self-hosted, local dev only) - see docker-compose.yml's `keycloak` service
# and infra/keycloak/realm-export.json. Will issue the JWTs a future apps/server verifies
# and PowerSync's client_auth accepts (via the "powersync-audience" mapper in
# realm-export.json) - neither exists yet, this is auth-only for now.
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=local_dev_only
# Host-perspective URLs (for apps/web/curl running on the host, not inside the Docker
# network) - must use KEYCLOAK_PORT above, not Keycloak's internal container port 8080.
# A container that needs these (e.g. PowerSync, later) must use the service name
# `keycloak` instead of `localhost`.
KEYCLOAK_ISSUER=http://localhost:8180/realms/app
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/app/protocol/openid-connect/certs
