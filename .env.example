# Copy to .env and adjust if needed. These are local-only dev defaults (see
# docker-compose.yml) - never put real/shared secrets in this file or .env.
# DATABASE_URL's port must match POSTGRES_PORT below - it's a separate file dotenv
# reads, no variable substitution between the two. Don't point this at PS_STORAGE_PORT
# (that's PowerSync's own internal metadata DB, not the app's data).
POSTGRES_PORT=5432
# Owner role (created migrations) - used by drizzle-kit generate/migrate, never by
# apps/server's runtime queries: this role bypasses Postgres RLS by default since it
# owns the tables (see docs/data-model.md's "Postgres RLS for multi-tenancy" section).
DATABASE_URL=postgres://effective_app:local_dev_only@localhost:5432/effective_app
# Non-owner role (postgres/init-scripts/02-app-user-role.sql) - what apps/server
# actually connects as, so RLS policies apply to its queries.
APP_DATABASE_URL=postgres://app_user:local_dev_only@localhost:5432/effective_app

MAILPIT_SMTP_PORT=11025
MAILPIT_WEB_PORT=18025

# PowerSync (self-hosted, local dev only) - see docker-compose.yml's `powersync`/
# `pg-storage` services and docs/data-model.md's "PowerSync sync streams" section.
PS_PORT=8080
PS_API_TOKEN=local_dev_only_change_me
PS_STORAGE_USER=postgres
PS_STORAGE_PASSWORD=local_dev_only
PS_STORAGE_DATABASE=powersync_storage
PS_STORAGE_PORT=5434
# Password for the least-privilege `powersync_replication` role (REPLICATION +
# read-only, postgres/init-scripts/03-powersync-replication-role.sql) that PowerSync's
# replication connection uses - never the `effective_app` table-owner role.
PS_REPLICATION_PASSWORD=local_dev_only

# Keycloak (self-hosted, local dev only) - see docker-compose.yml's `keycloak` service
# and keycloak/realm-export.json. Issues the JWTs apps/server's AuthService verifies and
# PowerSync's client_auth accepts (see powersync/service.yaml).
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=local_dev_only
# Host-perspective URLs (apps/server runs on the host, not in the docker network) -
# must use KEYCLOAK_PORT above, not Keycloak's internal container port 8080.
KEYCLOAK_ISSUER=http://localhost:8180/realms/effective-app
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/effective-app/protocol/openid-connect/certs

