# Copy to .env and adjust if needed. These are local-only dev defaults (see
# docker-compose.yml) - never put real/shared secrets in this file or .env.
# Off the standard 5432 on purpose, to avoid colliding with other Postgres instances
# already running on your machine (e.g. other projects' dev servers).
POSTGRES_PORT=5442
DATABASE_URL=postgres://effective_app:local_dev_only@localhost:5442/effective_app

MAILPIT_SMTP_PORT=11025
MAILPIT_WEB_PORT=18025
