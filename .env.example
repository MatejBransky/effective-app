# Copy to .env and adjust if needed. These are local-only dev defaults (see
# docker-compose.yml) - never put real/shared secrets in this file or .env.
# Off the standard 5432 on purpose, to avoid colliding with other Postgres instances
# already running on your machine (e.g. other projects' dev servers).
# DATABASE_URL's port must match POSTGRES_PORT below - it's a separate file dotenv
# reads, no variable substitution between the two. Don't point this at PS_STORAGE_PORT
# (that's PowerSync's own internal metadata DB, not the app's data).
POSTGRES_PORT=5442
# Owner role (created migrations) - used by drizzle-kit generate/migrate, never by
# apps/server's runtime queries: this role bypasses Postgres RLS by default since it
# owns the tables (see docs/data-model.md's "Postgres RLS for multi-tenancy" section).
DATABASE_URL=postgres://effective_app:local_dev_only@localhost:5442/effective_app
# Non-owner role (postgres/init-scripts/02-app-user-role.sql) - what apps/server
# actually connects as, so RLS policies apply to its queries.
APP_DATABASE_URL=postgres://app_user:local_dev_only@localhost:5442/effective_app

MAILPIT_SMTP_PORT=11025
MAILPIT_WEB_PORT=18025

# PowerSync (self-hosted, local dev only) - see docker-compose.yml's `powersync`/
# `pg-storage` services and docs/data-model.md's "PowerSync sync streams" section.
PS_PORT=8080
PS_API_TOKEN=local_dev_only_change_me
PS_STORAGE_USER=postgres
PS_STORAGE_PASSWORD=local_dev_only
PS_STORAGE_DATABASE=powersync_storage
PS_STORAGE_PORT=5434
# Password for the least-privilege `powersync_replication` role (REPLICATION +
# read-only, postgres/init-scripts/03-powersync-replication-role.sql) that PowerSync's
# replication connection uses - never the `effective_app` table-owner role.
PS_REPLICATION_PASSWORD=local_dev_only

# Keycloak (self-hosted, local dev only) - see docker-compose.yml's `keycloak` service
# and keycloak/realm-export.json. Issues the JWTs apps/server's AuthService verifies and
# PowerSync's client_auth accepts (see powersync/service.yaml).
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=local_dev_only
# Host-perspective URLs (apps/server runs on the host, not in the docker network) -
# must use KEYCLOAK_PORT above, not Keycloak's internal container port 8080.
KEYCLOAK_ISSUER=http://localhost:8180/realms/effective-app
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/effective-app/protocol/openid-connect/certs

# Off the standard 3000 on purpose, to avoid colliding with other local dev servers.
PORT=4000
# apps/server's CORS allowlist - apps/client calls it cross-origin (5173 -> 4000).
CLIENT_ORIGIN=http://localhost:5173

# apps/client (Vite exposes only VITE_-prefixed vars to browser code - never put a
# secret here, this ends up in the built JS bundle).
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=effective-app
VITE_KEYCLOAK_CLIENT_ID=effective-app-client
VITE_SERVER_URL=http://localhost:4000
VITE_POWERSYNC_URL=http://localhost:8080

# apps/infrastructure (Alchemy IaC) - unlike everything else in this file, these are
# REAL credentials, never dev-only placeholders. Get them from the Cloudflare
# dashboard (Account Home -> Account ID; My Profile -> API Tokens -> a scoped token,
# not the Global API Key) and put the real values only in your own untracked `.env`,
# never here. `alchemy dev`/`alchemy deploy` (apps/infrastructure) read these directly -
# see docs/data-model.md's "Cloudflare deployment (apps/infrastructure)" section for
# why even local `alchemy dev` needs a real account (no credential-free local mode).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# One-time, LOCAL-ONLY bootstrap credential for `apps/infrastructure/stacks/github.ts`
# (`pnpm --filter @effective-app/infrastructure run bootstrap-github`) - mints the
# scoped CLOUDFLARE_API_TOKEN above and writes it into this repo as a GitHub Actions
# secret, so CI never needs a human to paste credentials into the GitHub UI. Needs
# `API Tokens > Write`, which the scoped token above deliberately does NOT have -
# use the account's Global API Key (My Profile -> API Keys -> Global API Key), never
# used anywhere else, never used by CI itself. Re-run only to rotate/change CI's
# permissions - see docs/data-model.md's "GitHub CI/CD" section.
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# Also one-time, LOCAL-ONLY, for the same `bootstrap-github` run -
# `GitHub.Secret` needs its own credential to write secrets into the repo via the
# GitHub API. A logged-in `gh` CLI session is NOT picked up automatically (Alchemy
# reads this env var directly, not `gh`'s own credential store) - create a classic
# Personal Access Token (github.com/settings/tokens -> Generate new token (classic)
# -> `repo` scope) on the account that actually owns/administers this repository.
GITHUB_TOKEN=

