{
  "name": "effective-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "verify": "oxfmt --check && oxlint --disable-nested-config .",
    "verify:fix": "oxfmt && oxlint --disable-nested-config --fix .",
    "update:effect": "git subtree pull --prefix=repos/effect https://github.com/Effect-TS/effect.git main --squash"
  },
  "devDependencies": {
    "@repo/lint-config": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.13.0"
}
