# Copy to .env and adjust if needed. These are local-only dev defaults (see
# docker-compose.yml) - never put real/shared secrets in this file or .env.
# DATABASE_URL's port must match POSTGRES_PORT below - it's a separate file dotenv
# reads, no variable substitution between the two. Don't point this at PS_STORAGE_PORT
# (that's PowerSync's own internal metadata DB, not the app's data).
POSTGRES_PORT=5432
DATABASE_URL=postgres://effective_app:local_dev_only@localhost:5432/effective_app

MAILPIT_SMTP_PORT=11025
MAILPIT_WEB_PORT=18025

# PowerSync (self-hosted, local dev only) - see docker-compose.yml's `powersync`/
# `pg-storage` services and docs/data-model.md's "PowerSync sync streams" section.
PS_PORT=8080
PS_API_TOKEN=local_dev_only_change_me
PS_STORAGE_USER=postgres
PS_STORAGE_PASSWORD=local_dev_only
PS_STORAGE_DATABASE=powersync_storage
PS_STORAGE_PORT=5434
# HS256 shared secret PowerSync uses to verify locally-generated dev JWTs
# (`npx powersync generate token`). Generate your own with:
# `openssl rand -base64 32 | tr '+/' '-_' | tr -d '='` - never reuse this value, and
# never use an HS256 shared secret like this in production.
PS_CLIENT_AUTH_KEY=wLGH09u8pY5DaDP0XNU_8w0g6oo5AFI1Esn3YvQ-pn8

