{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/shared-typescript-config/base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "types": ["node"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "rootDir": "."
